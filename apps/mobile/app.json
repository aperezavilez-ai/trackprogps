{
  "expo": {
    "name": "TrackPro GPS",
    "slug": "trackpro-gps",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A5F"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "mx.trackpro.app",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "TrackPro necesita acceder a tu ubicación para mostrar tu posición en el mapa.",
        "NSLocationAlwaysUsageDescription": "TrackPro usa tu ubicación para rastrear la flota.",
        "CFBundleDisplayName": "TrackPro GPS"
      },
      "associatedDomains": ["applinks:trackprogps.mx"]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1E3A5F"
      },
      "package": "mx.trackpro.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2563EB"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "TrackPro necesita acceder a tu ubicación para mostrar tu posición en el mapa."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "placeholder"
      },
      "router": {
        "origin": false
      },
      "privacyPolicyUrl": "https://trackprogps.mx/legal/privacidad",
      "termsUrl": "https://trackprogps.mx/legal/terminos",
      "webAppUrl": "https://trackprogps.mx"
    },
    "scheme": "trackprogps",
    "owner": "trackpro"
  }
}
