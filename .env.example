# Copia a .env y completa con valores reales (nunca subas .env al repo)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DB_PASSWORD=your_database_password

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
NEXT_PUBLIC_GOOGLE_MAPS_ENABLED=true
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

GPS_SERVER_PORT=5000
GPS_SERVER_HOST=0.0.0.0
HEALTH_PORT=3001
REDIS_URL=rediss://default:TOKEN@HOST.upstash.io:6379

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alertas@trackprogps.mx
RESEND_FROM_NOREPLY=noreply@trackprogps.mx
RESEND_FROM_BILLING=facturacion@trackprogps.mx

WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

FCM_SERVER_KEY=

# Web Push PWA (generar: node scripts/generate-vapid-keys.mjs)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:alertas@trackprogps.mx

ANTHROPIC_API_KEY=

NEXT_PUBLIC_APP_URL=https://trackprogps.mx
NEXT_PUBLIC_APP_NAME=TrackPro GPS
NEXT_PUBLIC_DEMO_MODE=false

# Scripts internos (opcional)
SUPABASE_DB_PASSWORD=your_database_password
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password
ADMIN_NAME=Admin
