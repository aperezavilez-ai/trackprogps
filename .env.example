# ============================================================
# GPS SaaS - Variables de entorno
# Copia este archivo como .env.local y llena los valores
# NUNCA commitas el .env.local al repositorio
# ============================================================

# ----------------------------
# SUPABASE
# ----------------------------
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ... (anon key)
SUPABASE_SERVICE_ROLE_KEY=eyJ... (service role key - SECRETO)

# ----------------------------
# GOOGLE MAPS
# ----------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# ----------------------------
# GPS SERVER
# ----------------------------
GPS_SERVER_PORT=5000
GPS_SERVER_HOST=0.0.0.0
HEALTH_PORT=3001
REDIS_URL=redis://localhost:6379

# ----------------------------
# STRIPE (pagos)
# ----------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ----------------------------
# CONEKTA (México - alternativa a Stripe)
# ----------------------------
CONEKTA_PRIVATE_KEY=key_...
CONEKTA_WEBHOOK_SECRET=...

# ----------------------------
# NOTIFICACIONES
# ----------------------------
# Email via Resend
RESEND_API_KEY=re_...

# WhatsApp via Meta Cloud API
WHATSAPP_TOKEN=EAAa...
WHATSAPP_PHONE_ID=1234567890

# Firebase Cloud Messaging (Push)
FCM_SERVER_KEY=AAAA...

# ----------------------------
# IA - Anthropic
# ----------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ----------------------------
# APP
# ----------------------------
NEXT_PUBLIC_APP_URL=https://app.trackpro.mx
NEXT_PUBLIC_APP_NAME=TrackPro GPS
